{
  "_comment": "单批次 Excel 列定义。**这份 schema 是 phase4-export-excel.mjs 的契约 —— 改动 phase4 必须同步更新此文件，schema-check.mjs 会做一致性校验。**",
  "_path": "~/.linkedin-talent/batches/linkedin_<batch_id>.xlsx",
  "filename_pattern": "~/.linkedin-talent/batches/linkedin_{batch_id}.xlsx",
  "sheets": {
    "passed": {
      "name": "候选人",
      "sort_by": "score DESC",
      "columns": [
        {"col": "A", "header": "序号",                    "field": "row_index"},
        {"col": "B", "header": "Tier",                    "field": "tier_with_stars",        "format": "<tier> ⭐⭐⭐|⭐⭐|⭐"},
        {"col": "C", "header": "总分",                    "field": "score"},
        {"col": "D", "header": "分项评分",                 "field": "scores_breakdown_str",    "format": "公司:90 / 岗位:75 / 目标岗时长:80 / 加分:50"},
        {"col": "E", "header": "姓名",                    "field": "name"},
        {"col": "F", "header": "当前职位",                 "field": "current_title"},
        {"col": "G", "header": "当前公司",                 "field": "current_company"},
        {"col": "H", "header": "目标公司经历",              "field": "target_experience",       "format": "公司|职位|起止年（多段换行）"},
        {"col": "I", "header": "其他经历",                 "field": "other_experience",        "format": "同上，最多 3 段"},
        {"col": "J", "header": "学历",                    "field": "education",               "format": "学校 · 学位 · 专业（多段换行）"},
        {"col": "K", "header": "地点",                    "field": "location"},
        {"col": "L", "header": "评分理由",                 "field": "reasoning"},
        {"col": "M", "header": "matched_signals",         "field": "matched_signals",         "format": "join('; ')"},
        {"col": "N", "header": "missed_signals",          "field": "missed_signals",          "format": "join('; ')"},
        {"col": "O", "header": "highlight_for_outreach",  "field": "highlight_for_outreach"},
        {"col": "P", "header": "Connect 话术",            "field": "connect_message",         "note": "type1/2 ≤ 290 字符；用 lib/connect-templates.json 渲染"},
        {"col": "Q", "header": "Profile URL",             "field": "profile_url"},
        {"col": "R", "header": "Vanity",                  "field": "vanity"},
        {"col": "S", "header": "URN",                     "field": "urn"},
        {"col": "T", "header": "搜索命中",                 "field": "hits_summary",            "format": "kw@strategy + kw@strategy"},
        {"col": "U", "header": "评分方式",                 "field": "scored_by",               "values": ["rule", "llm"]},
        {"col": "V", "header": "Connect状态",             "field": "connect_status",          "values": ["待确认", "已发送", "CANT_RESEND", "失败"]}
      ],
      "column_widths": [5, 8, 6, 28, 18, 22, 16, 30, 30, 25, 14, 35, 30, 30, 40, 60, 45, 25, 40, 30, 8, 8],
      "wrap_text_columns": ["H", "I", "L", "O", "P"]
    },
    "failed": {
      "name": "淘汰名单",
      "columns": [
        {"col": "A", "header": "姓名",       "field": "name"},
        {"col": "B", "header": "Headline",  "field": "headline"},
        {"col": "C", "header": "Vanity",    "field": "vanity"},
        {"col": "D", "header": "淘汰原因",   "field": "reason"}
      ],
      "column_widths": [18, 40, 25, 30]
    },
    "stats": {
      "name": "统计",
      "columns": [
        {"col": "A", "header": "指标"},
        {"col": "B", "header": "数值"}
      ],
      "rows": [
        "总召回",
        "预筛丢弃",
        "实际拉取 Profile",
        "L2 通过",
        "L2 失败",
        "Tier 1 (⭐⭐⭐)",
        "Tier 2 (⭐⭐)",
        "Tier 3 (⭐)",
        "生成时间"
      ],
      "column_widths": [22, 14]
    }
  },
  "rules": {
    "tier_to_rating": {"1": "⭐⭐⭐", "2": "⭐⭐", "3": "⭐"},
    "connect_status_default": "待确认",
    "freeze_top_row": true
  }
}
